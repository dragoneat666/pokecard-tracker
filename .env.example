# GitHub — your GitHub username, used to pull images from ghcr.io
GITHUB_USERNAME=your_github_username

# PostgreSQL
DB_NAME=pokecard
DB_USER=pokecard_user
DB_PASSWORD=change_me_to_something_strong

# TCG Card Data API — PokéWallet
# Sign up free at https://www.pokewallet.io — 1,000 requests/day free
TCG_API_KEY=your_api_key_here
TCG_API_PROVIDER=pokewallet
